@model WebApplication1.Models.ObstacleData
@{
    ViewData["Title"] = "Obstacle Overview";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    #mapOverview {
        height: 320px;
        border-radius: 10px;
        margin-top: 1rem;
    }</style>

<h2>Obstacle Overview</h2>
<ul>
    <li><strong>Name:</strong> @Model.ObstacleName</li>
    <li><strong>Height:</strong> @Model.ObstacleHeight m</li>
    <li><strong>Description:</strong> @Model.ObstacleDescription</li>
    <li><strong>Lat:</strong> @Model.ObstacleLatitude</li>
    <li><strong>Lon:</strong> @Model.ObstacleLongitude</li>
    @if (!string.IsNullOrWhiteSpace(Model.ObstacleType))
    {
        <li><strong>Type:</strong> @Model.ObstacleType</li>
    }
    @if (Model.ObstacleType == "circle" && Model.ObstacleRadius.HasValue)
    {
        <li><strong>Radius:</strong> @Model.ObstacleRadius m</li>
    }
    @if (Model.ObstacleType == "polyline" && !string.IsNullOrWhiteSpace(Model.ObstacleLineCoords))
    {
        <li><strong>Line points:</strong> @Model.ObstacleLineCoords</li>
    }
    @if (Model.ReporterLatitude.HasValue && Model.ReporterLongitude.HasValue)
    {
        <li><strong>Captured from device:</strong> @Model.ReporterLatitude, @Model.ReporterLongitude (@Model.ReporterAccuracy m)</li>
        <li><strong>Captured at (UTC):</strong> @Model.CapturedAt</li>
    }
</ul>

<div id="mapOverview"></div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        (function(){
          const lat = @Model.ObstacleLatitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
          const lon = @Model.ObstacleLongitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
          const type = "@(Model.ObstacleType ?? "")";
          const radius = @(Model.ObstacleRadius.HasValue? Model.ObstacleRadius.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null");
          const lineJson = `@(Model.ObstacleLineCoords ?? "")`;

          const map = L.map('mapOverview').setView([lat, lon], 15);
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OSM' }).addTo(map);

          try {
            if (type === "circle" && radius != null) {
              L.circle([lat, lon], { radius: Number(radius) }).addTo(map);
            } else if (type === "polyline" && lineJson.length > 0) {
              const coords = JSON.parse(lineJson); // [[lat,lon], ...]
              const line = L.polyline(coords.map(p => [p[0], p[1]])).addTo(map);
              map.fitBounds(line.getBounds(), { padding: [20,20] });
            } else {
              L.marker([lat, lon]).addTo(map);
            }
          } catch (e) {
            console.warn("Failed to render shape, falling back to marker", e);
            L.marker([lat, lon]).addTo(map);
          }
        })();
    </script>
}
